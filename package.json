{
  "name": "clean-ast-linter",
  "displayName": "Clean AST Linter",
  "description": "Deterministic local static analysis using Tree-sitter AST",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clean-ast-linter.helloWorld",
        "title": "Hello World"
      }
    ],
    "configuration": {
      "title": "Clean AST Linter",
      "properties": {
        "cleanAstLinter.maxFunctionLines": {
          "type": "number",
          "default": 50,
          "description": "Maximum allowed lines for a single function."
        },
        "cleanAstLinter.maxParameters": {
          "type": "number",
          "default": 4,
          "description": "Maximum allowed parameters in a function signature."
        },
        "cleanAstLinter.maxComplexity": {
          "type": "number",
          "default": 10,
          "description": "Maximum allowed cyclomatic complexity for a function."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "formatter": "prettier --write src",
    "knip": "knip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "knip": "^6.17.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.9"
  }
}
